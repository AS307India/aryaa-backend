datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id                    String                 @id @default(uuid())
  name                  String
  email                 String                 @unique
  phone                 String                 @unique
  password              String
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  contacts              Contact[]
  sosEvents             SosEvent[]
  deadZoneCheckIns      DeadZoneCheckIn[]
  fcmToken              String?
  locationShareSessions LocationShareSession[]
  homeAddress           String?
  homeLatitude          Float?
  homeLongitude         Float?
  safetyReports         SafetyReport[]
}

model Contact {
  id           String   @id @default(uuid())
  name         String
  phone        String
  relationship String   // FAMILY, FRIEND, COLLEAGUE, NEIGHBOUR, OTHER
  isNearby     String   @default("SOMETIMES") // "YES" | "NO" | "SOMETIMES"
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  locationShareContacts LocationShareContact[]
}

model SosEvent {
  id                String              @id @default(uuid())
  userId            String
  user              User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  status            String              // "ACTIVE" | "CANCELLED" | "RESOLVED" | "DURESS"
  publicTrackToken  String?             @unique
  latitude          Float?
  longitude         Float?
  address           String?
  w3wAddress        String?
  triggeredAt       DateTime            @default(now())
  cancelledAt       DateTime?
  resolvedAt        DateTime?
  duressTriggeredAt DateTime?
  accuracy          Float?
  contacts          SosContact[]
  locationUpdates   SosLocationUpdate[]
  responses         SosResponse[]
}

model SosContact {
  id         String   @id @default(uuid())
  sosEventId String
  sosEvent   SosEvent @relation(fields: [sosEventId], references: [id], onDelete: Cascade)
  name       String
  phone      String
  isNearby     String   @default("SOMETIMES") // Snapshot of tier at trigger time
}

model SosResponse {
  id          String   @id @default(uuid())
  sosEventId  String
  sosEvent    SosEvent @relation(fields: [sosEventId], references: [id], onDelete: Cascade)
  phone       String
  respondedAt DateTime @default(now())
}

model SosLocationUpdate {
  id         String   @id @default(uuid())
  sosEventId String
  sosEvent   SosEvent @relation(fields: [sosEventId], references: [id], onDelete: Cascade)
  latitude   Float
  longitude  Float
  timestamp  DateTime
}

model DeadZoneCheckIn {
  id                     String    @id @default(uuid())
  userId                 String
  user                   User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  status                 String    // "PENDING" | "CHECKED_IN" | "MISSED" | "ALERTED"
  mode                   String    @default("PLAIN") // "PLAIN" | "SAFE_WALK" | "HEARTBEAT"
  destination            String?   
  intervalMinutes        Int?      
  locationShareSessionId String?   
  startedAt              DateTime  @default(now())
  expectedBackAt         DateTime  // startedAt + user-selected duration
  gracePeriodEnd         DateTime  // expectedBackAt + 30 minutes
  checkedInAt            DateTime?
  lastLatitude           Float?    // last known location BEFORE entering dead zone
  lastLongitude          Float?
  lastAccuracy           Float?
  alertedAt              DateTime?
}

model LocationShareSession {
  id         String                 @id @default(uuid())
  userId     String
  user       User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  token      String                 @unique
  expiresAt  DateTime
  active     Boolean                @default(true)
  createdAt  DateTime               @default(now())
  locations  LocationShareHistory[]
  contacts   LocationShareContact[]
}

model LocationShareContact {
  id         String               @id @default(uuid())
  sessionId  String
  session    LocationShareSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  contactId  String
  contact    Contact              @relation(fields: [contactId], references: [id], onDelete: Cascade)
}

model LocationShareHistory {
  id         String               @id @default(uuid())
  sessionId  String
  session    LocationShareSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  latitude   Float
  longitude  Float
  accuracy   Float?
  timestamp  DateTime
}

model SafetyReport {
  id            String    @id @default(uuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userPhone     String
  category      String    // "HARASSMENT" | "POOR_LIGHTING" | "THEFT" | "UNSAFE_ROAD" | "OTHER"
  description   String
  latitude      Float
  longitude     Float
  createdAt     DateTime  @default(now())
  status        String    @default("ACTIVE") // "ACTIVE" | "UNDER_REVIEW" | "REMOVED_BY_ADMIN"
  isPublicSpace Boolean   @default(false)
  disputedBy    String?
  disputedAt    DateTime?
}

